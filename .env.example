# LLM API Keys
GOOGLE_API_KEY=your_google_api_key_here

# Mock Mode Configuration
MOCK_LLM=true

# Model Configurations (Gemini 2.5)
MODEL_SUPERVISOR=gemini-2.5-pro
MODEL_PLANNER=gemini-2.5-flash
MODEL_CODER=gemini-2.5-flash
MODEL_REVIEWER=gemini-2.5-pro
MODEL_DEBUGGER=gemini-2.5-flash
MODEL_DOCS=gemini-2.5-flash

# Sandbox Configuration
DOCKER_IMAGE=assistant-sandbox:latest
SANDBOX_TIMEOUT=15
SANDBOX_MEMORY_LIMIT=64m

# Orchestrator Configuration
MAX_ITERATIONS=15
PORT=8000
